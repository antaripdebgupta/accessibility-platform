ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string-in-production

ALLOWED_ORIGINS_STR=http://localhost,http://localhost:5173,http://127.0.0.1

# PostgreSQL Database
POSTGRES_USER=a11y
POSTGRES_PASSWORD=a11ypass
POSTGRES_DB=accessibility_db

# Full connection URL (used by the API)
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+asyncpg://a11y:a11ypass@postgres:5432/accessibility_db

# Redis (Celery Broker & Cache)
REDIS_URL=redis://redis:6379/0

FIREBASE_PROJECT_ID=your-firebase-project-id

# Path to the service account JSON key file
# In Docker, this is mounted to /run/secrets/firebase_sa.json
# Leave empty when using Firebase emulator in development
FIREBASE_SERVICE_ACCOUNT_KEY=

# MinIO Object Storage (S3-compatible)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_REPORTS=reports
MINIO_BUCKET_SCREENSHOTS=screenshots
MINIO_SECURE=false

# Crawler Settings
DEFAULT_MAX_PAGES=15
CRAWLER_TIMEOUT_MS=30000

# Frontend (Vite Environment Variables)
# These must be prefixed with VITE_ to be available in the browser
# Get these from Firebase Console → Project Settings → General → Your apps
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# Firebase Emulator (for local development only)
VITE_USE_FIREBASE_EMULATOR=false
VITE_FIREBASE_EMULATOR_HOST=127.0.0.1
VITE_FIREBASE_AUTH_EMULATOR_PORT=9099
