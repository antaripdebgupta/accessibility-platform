# Example Vite environment variables for Firebase
# Copy this to frontend/.env.local and fill with your project's values for production
# Do NOT commit real credentials to git.

VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# Note: In development, the app will automatically try to connect to the
# Firebase Auth Emulator at http://localhost:9099 when import.meta.env.DEV is true.
# Frontend env example for Vite (DO NOT COMMIT real secrets)
# Copy to frontend/.env.local and edit values for your environment.

# Vite env variables must start with VITE_
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=accessibility-platform-dev

# Optional: override emulator host/ports when running the emulator locally
VITE_FIREBASE_EMULATOR_HOST=127.0.0.1
VITE_FIREBASE_AUTH_EMULATOR_PORT=9099
VITE_FIREBASE_FIRESTORE_EMULATOR_PORT=8080
